# --------------------------------------------------------------------
# Non-secret values — copy this file to web/.env.local on the host
# (or let deploy\local-bootstrap.ps1 do it for you).
# --------------------------------------------------------------------

# Public base URL of the Better-Auth install.
#   Dev:  http://localhost:3000
#   Prod: https://<host>     (must match the IIS binding)
BETTER_AUTH_URL=http://localhost:3000

# Absolute paths on the host.
RESUMES_DIR=C:\Users\Administrator\Pictures\Application Tracking System\data\resumes
LOGS_DIR=C:\Users\Administrator\Pictures\Application Tracking System\data\logs

# --------------------------------------------------------------------
# SECRETS
# --------------------------------------------------------------------
# Source of truth lives in Windows Credential Manager (service "ATS").
# Provision them with:
#   npx tsx scripts/secrets-set.ts --key DATABASE_URL
#   npx tsx scripts/secrets-set.ts --key BETTER_AUTH_SECRET
#
# Local development (Next.js dev server, scripts):
#   `deploy\local-bootstrap.ps1` reads the values from Credential Manager
#   and appends them to web/.env.local so Next.js can auto-load them.
#   web/.env.local is gitignored.
#
# Production (NSSM-supervised):
#   Recommended: run a thin wrapper that reads keytar at service start
#   and exports DATABASE_URL / BETTER_AUTH_SECRET into the child process
#   environment, instead of writing them to disk.
# --------------------------------------------------------------------
# DATABASE_URL=mysql://ats_app:<pwd>@127.0.0.1:3306/ats
# BETTER_AUTH_SECRET=<64-char-random-hex>
